# workspaces.yaml — Multi-repo monitoring configuration
#
# Place this file at your PROJECT_ROOT (or set WORKSPACES_FILE in .env).
# Absence of this file = backward-compat single-repo mode (DEVTRACK_WORKSPACE used).
#
# pm_platform options: azure | gitlab | github | jira | none
# pm_project: optional platform-specific project key (GitLab project ID, Azure project name, etc.)
#
# Per-workspace PM settings (pm_assignee, pm_iteration_path, pm_area_path, pm_milestone):
#   These override the global defaults previously set via .env.
#   Leave blank / 0 to use the platform default (e.g. unassigned, no sprint, no milestone).
#

version: "1"
workspaces:
  - name: "work-api"
    path: "~/work/api"
    pm_platform: "azure"
    pm_project: ""          # leave blank to use AZURE_DEVOPS_PROJECT from .env
    enabled: true
    ignore_branches: ["main", "master"]
    tags: ["work"]
    # Per-workspace PM settings:
    pm_assignee: ""              # Azure: assigned_to (e.g. john@company.com)
    pm_iteration_path: ""        # Azure: sprint/iteration path (e.g. "MyProject\\Sprint 5")
    pm_area_path: ""             # Azure: area path (e.g. "MyProject\\Backend")
    pm_milestone: 0              # GitHub: milestone number; GitLab: milestone_id (0 = none)

  - name: "oss-lib"
    path: "~/oss/my-lib"
    pm_platform: "github"
    pm_project: ""          # uses GITHUB_OWNER/GITHUB_REPO from .env
    enabled: true
    ignore_branches: []
    tags: ["oss"]
    pm_assignee: ""
    pm_milestone: 0

  - name: "internal-tools"
    path: "~/work/tools"
    pm_platform: "gitlab"
    pm_project: "12345"     # GitLab project ID (overrides GITLAB_PROJECT_ID from .env)
    enabled: true
    ignore_branches: []
    tags: ["work"]
    pm_assignee: ""
    pm_milestone: 0              # GitLab: milestone_id
