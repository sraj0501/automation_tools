# DevTrack .env_sample — copy to .env and fill in your values

## All variables are required unless marked optional

## PATHS

### Directory Paths and Repository Root

### Absolute path to the automation_tools repo root (required)

PROJECT_ROOT=/path/to/automation_tools
DEVTRACK_HOME=${PROJECT_ROOT}/devtrack-bin

### Multi-repo mode

#### When workspaces.yaml exists at PROJECT_ROOT, DEVTRACK_WORKSPACE is ignored

WORKSPACES_FILE=/custom/path/to/workspaces.yaml   (optional override)

#### DEVTRACK_WORKSPACE: Path to the single git repo to monitor

#### Optional when workspaces.yaml is present (multi-repo mode)

#### Required only for single-repo mode

# Set to the repo you want monitored (default: same repo as PROJECT_ROOT)
# DEVTRACK_WORKSPACE=/path/to/your/other/repo   # single-repo override
DEVTRACK_WORKSPACE=${PROJECT_ROOT}

DATA_DIR=${PROJECT_ROOT}/Data
DATABASE_DIR=${DATA_DIR}/db
LOG_DIR=${DATA_DIR}/logs
PID_DIR=${DATA_DIR}/pids
CONFIG_DIR_PATH=${DATA_DIR}/configs
LEARNING_DIR_PATH=${DATA_DIR}/learning

## DAEMON / CLI INTERNALS

### Server Architecture and Backend Management

How the Python backend is managed

managed  (default) — devtrack start spawns Python backend as a subprocess

external           — Python backend runs separately; daemon will not spawn it

DEVTRACK_SERVER_MODE=managed

# URL of the Python backend server
# Managed mode: auto-defaults to https://127.0.0.1:<WEBHOOK_PORT> — no change needed
# Override for external/cloud deployments only
# External local: DEVTRACK_SERVER_URL=https://localhost:8089
# Cloud:          DEVTRACK_SERVER_URL=https://your-devtrack-server.com

DEVTRACK_SERVER_URL=

TLS — Go↔Python channel encryption (default: true)

Go generates a self-signed ECDSA cert at startup; Python uvicorn uses it

Disable only for Docker internal networks or trusted dev environments

DEVTRACK_TLS=true

TLS cert/key paths — auto-set by the daemon on each start

Override only if supplying your own certificate (e.g. for cloud with a CA-signed cert)

DEVTRACK_TLS_CERT=Data/tls/server.crt

DEVTRACK_TLS_KEY=Data/tls/server.key

API key sent as X-DevTrack-API-Key header on all /trigger/* requests

Required for cloud/public deployments. Auto-populated by 'devtrack cloud login'

Safe to leave blank for localhost-only use

DEVTRACK_API_KEY=

### IPC and Daemon Configuration

IPC_HOST=127.0.0.1
IPC_PORT=35893
IPC_CONNECT_TIMEOUT_SECS=5
PYTHON_BRIDGE_SCRIPT=python_bridge.py
CLI_BINARY_NAME=devtrack
CONFIG_FILE_NAME=config.yaml
DATABASE_FILE_NAME=devtrack.db
PID_FILE_NAME=daemon.pid
LOG_FILE_NAME=daemon.log
LEARNING_DIR_NAME=learning
CONFIG_DIR_NAME=.devtrack
CLI_APP_NAME=DevTrack
CLI_DAEMON_NAME=devtrack

Set to true to commit without pushing (useful when post-commit hooks do the push)

DEVTRACK_COMMIT_ONLY=false

## LLM PROVIDERS

### Primary Provider Selection

Primary LLM provider for devtrack (commit messages, reports, descriptions)

Values: ollama | openai | groq | anthropic | lmstudio

LLM_PROVIDER=ollama

### Ollama (local, free)

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

### LM Studio (local, OpenAI-compatible)

LMSTUDIO_HOST=http://localhost:1234/v1

### OpenAI (optional — used as primary or fallback when OPENAI_API_KEY is set)

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

### Anthropic (optional — used as primary or fallback when ANTHROPIC_API_KEY is set)

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

### Groq (optional — used as primary or fallback when GROQ_API_KEY is set)

GROQ_API_KEY=
GROQ_HOST=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

## GIT-SAGE (devtrack sage)

### =============================================================================

# Provider for git-sage specifically. Defaults to LLM_PROVIDER if not set

# Values: ollama | openai | groq | anthropic | lmstudio

GIT_SAGE_PROVIDER=ollama
GIT_SAGE_DEFAULT_MODEL=llama3.2

GIT_SAGE_BASE_URL=          (optional: override base URL for git-sage provider)

GIT_SAGE_API_KEY=           (optional: override API key for git-sage provider)

## LLM GENERATION PARAMETERS

### =============================================================================

Temperature: 0.0 = deterministic, 1.0 = creative

Max tokens: output length limit

COMMIT_LLM_TEMPERATURE=0.1
COMMIT_LLM_MAX_TOKENS=1000

REPORT_LLM_TEMPERATURE=0.3
REPORT_LLM_MAX_TOKENS=600

PERSONALIZATION_LLM_TEMPERATURE=0.7
PERSONALIZATION_LLM_MAX_TOKENS=300

DESCRIPTION_LLM_TEMPERATURE=0.3
DESCRIPTION_LLM_MAX_TOKENS=300

## TIMEOUTS AND DELAYS (required — no defaults)

HTTP_TIMEOUT_SHORT=10
HTTP_TIMEOUT=30
HTTP_TIMEOUT_LONG=60
IPC_RETRY_DELAY_MS=2000
LLM_REQUEST_TIMEOUT_SECS=120
PROMPT_TIMEOUT_SIMPLE_SECS=30
PROMPT_TIMEOUT_WORK_SECS=60
PROMPT_TIMEOUT_TASK_SECS=120
SENTIMENT_ANALYSIS_WINDOW_MINUTES=120

## APPLICATION SETTINGS

PROMPT_INTERVAL=30
WORK_HOURS_ONLY=true
WORK_START_HOUR=9
WORK_END_HOUR=18
TIMEZONE=UTC
LOG_LEVEL=info
AUTO_SYNC=true
OUTPUT_TYPE=both
DAILY_REPORT_TIME=18:00
WEEKLY_REPORT_DAY=Friday
SEND_ON_TRIGGER=false
SEND_DAILY_SUMMARY=true

## EXTERNAL INTEGRATIONS

### Azure DevOps

AZURE_DEVOPS_PAT=your_azure_devops_pat_here
AZURE_ORGANIZATION=your_azure_org
AZURE_PROJECT=your_azure_project
AZURE_API_KEY=your_azure_devops_api_key_here
AZURE_API_VERSION=7.1
AZURE_EXCEL_FILE=${PROJECT_ROOT}/backend/data/tasks.xlsx
AZURE_EXCEL_SHEET=my_tasks
AZURE_PARENT_WORK_ITEM_ID=
AZURE_STARTING_WORK_ITEM_ID=0
EMAIL=your_email@example.com

### GitHub

GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=
GITHUB_API_URL=                             # leave blank for github.com; set for GitHub Enterprise
GITHUB_API_VERSION=2022-11-28               # GitHub REST API version header

### GitHub Bidirectional Sync

GITHUB_SYNC_ENABLED=false
GITHUB_AUTO_COMMENT=true
GITHUB_AUTO_TRANSITION=false
GITHUB_CREATE_ON_NO_MATCH=false
GITHUB_MATCH_THRESHOLD=0.6
GITHUB_DONE_STATE=closed
GITHUB_SYNC_LABEL=devtrack
GITHUB_AUTO_UPDATE_DESCRIPTION=false  # Append latest commit info to matched issue description

### GitLab

GITLAB_URL=https://gitlab.com
GITLAB_PAT=your_gitlab_personal_access_token
GITLAB_PROJECT_ID=                      # numeric project ID (required for create/milestones)
GITLAB_SYNC_ENABLED=false
GITLAB_SYNC_WINDOW_HOURS=0              # 0=full, N=last N hours
GITLAB_AUTO_COMMENT=true
GITLAB_AUTO_TRANSITION=false
GITLAB_CREATE_ON_NO_MATCH=false
GITLAB_MATCH_THRESHOLD=0.6
GITLAB_DONE_STATE=closed
GITLAB_SYNC_LABEL=devtrack
GITLAB_AUTO_UPDATE_DESCRIPTION=false  # Append latest commit info to matched issue description
GITLAB_POLL_ENABLED=false
GITLAB_POLL_INTERVAL_MINS=5

### Project Management Agent

PM_AGENT_MAX_ITEMS_PER_LEVEL=10
PM_AGENT_DEFAULT_PLATFORM=azure

### Jira Integration

JIRA_API_TOKEN=your_jira_api_token_here
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=your_email@example.com
JIRA_PROJECT_KEY=PROJ

### Email and Microsoft Teams

EMAIL_TO_ADDRESSES=dev@example.com
EMAIL_CC_ADDRESSES=manager@example.com
EMAIL_MANAGER=manager@example.com
EMAIL_SUBJECT="DevTrack Daily Report"
TEAMS_CHANNEL_ID=your_teams_channel_id
TEAMS_CHANNEL_NAME="DevTrack Updates"
TEAMS_CHAT_ID=your_teams_chat_id
TEAMS_CHAT_TYPE=channel
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url
TEAMS_MENTION_USER=false

#### Teams sentiment analysis — target sender name for responsiveness tracking

SENTIMENT_TARGET_SENDER=

## SEMANTIC MODEL

### =============================================================================

SEMANTIC_MODEL_NAME=all-MiniLM-L6-v2

## LEARNING AND PERSONALIZATION

### RAG and Vector Store

LEARNING_PYTHON_PATH=python3
LEARNING_SCRIPT_PATH=${PROJECT_ROOT}/backend/learning_integration.py
LEARNING_DAILY_SCRIPT_PATH=${PROJECT_ROOT}/backend/run_daily_learning.py
LEARNING_DEFAULT_DAYS=30

# Automatic daily cron collection

LEARNING_CRON_ENABLED=false
LEARNING_CRON_SCHEDULE="0 20 * * *"
LEARNING_HISTORY_DAYS=30

### RAG Personalization (vector-store few-shot examples, powered by ChromaDB + Ollama)

Requires: nomic-embed-text pulled in Ollama (`ollama pull nomic-embed-text`)

PERSONALIZATION_RAG_ENABLED=true
PERSONALIZATION_EMBED_MODEL=nomic-embed-text
PERSONALIZATION_RAG_K=3

Optional: override ChromaDB persistence directory (default: DATA_DIR/learning/chroma)

PERSONALIZATION_CHROMA_DIR=${DATA_DIR}/learning/chroma

## INFRASTRUCTURE (docker-compose)

### MongoDB

Leave MONGODB_URI empty to use file-based storage instead

MONGO_USER=devtrack
MONGO_PASSWORD=devtrack
MONGO_PORT=27017
MONGODB_DB_NAME=devtrack
MONGODB_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@localhost:${MONGO_PORT}/${MONGODB_DB_NAME}?authSource=admin

### Redis

REDIS_PASSWORD=devtrack
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:${REDIS_PORT}/0

### PostgreSQL

POSTGRES_USER=devtrack
POSTGRES_PASSWORD=devtrack
POSTGRES_DB=devtrack
POSTGRES_PORT=5432
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

## OFFLINE RESILIENCE, HEALTH CHECKS, AND QUEUE MANAGEMENT

### Store-and-Forward Queue, Health Monitoring, Deferred Commits

HEALTH_CHECK_INTERVAL_SECS=30
HEALTH_AUTO_RESTART_PYTHON=true
HEALTH_AUTO_RESTART_WEBHOOK=true
HEALTH_MAX_RESTARTS_PER_HOUR=3
QUEUE_DRAIN_INTERVAL_SECS=10
QUEUE_MAX_RETRIES=10
QUEUE_RETENTION_DAYS=7
DEFERRED_COMMIT_EXPIRY_HOURS=72

## TELEGRAM BOT (remote control via Telegram)

### Telegram Configuration

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_NOTIFY_COMMITS=false
TELEGRAM_NOTIFY_TRIGGERS=true
TELEGRAM_NOTIFY_HEALTH=true
HEALTH_AUTO_RESTART_TELEGRAM=true

## SLACK BOT

1. Create a Slack App at <https://api.slack.com/apps>

2. Enable Socket Mode (Settings > Socket Mode) → get App-Level Token (xapp-...)

3. Add slash command /devtrack (any Request URL — Socket Mode ignores it)

4. Add Bot Token Scopes: chat:write, commands, channels:read

5. Install to workspace → get Bot User OAuth Token (xoxb-...)

6. Invite the bot to your channels: /invite @devtrack

SLACK_ENABLED=false
SLACK_BOT_TOKEN=

xapp-... App-Level Token (requires connections:write scope)

SLACK_APP_TOKEN=

Comma-separated Slack channel IDs (e.g. C123ABC,C456DEF); empty = dev mode (all channels)

SLACK_ALLOWED_CHANNEL_IDS=

## BUILD METADATA

DEVTRACK_VERSION=0.1.0-alpha
DEVTRACK_BUILD_DATE=2026-03-02

## AZURE DEVOPS SYNC (bidirectional sync with Azure DevOps work items)

### Sync Configuration

AZURE_SYNC_ENABLED=false
AZURE_SYNC_AUTO_COMMENT=true
AZURE_SYNC_AUTO_TRANSITION=false
AZURE_SYNC_CREATE_ON_NO_MATCH=false
AZURE_SYNC_MATCH_THRESHOLD=0.7

# Sync window for devtrack azure-sync: 0 = full resync, N = last N hours only

AZURE_SYNC_WINDOW_HOURS=0

### Assignment Poller

Notify Telegram when a new work item is assigned to you

AZURE_POLL_ENABLED=false
AZURE_POLL_INTERVAL_MINS=5

## WEBHOOK SERVER (receives events from Azure DevOps, GitHub, Jira)

### Webhook Configuration

WEBHOOK_ENABLED=false
WEBHOOK_PORT=8089
WEBHOOK_HOST=0.0.0.0
WEBHOOK_AZURE_USERNAME=devtrack
WEBHOOK_AZURE_PASSWORD=
WEBHOOK_GITHUB_SECRET=
WEBHOOK_GITLAB_SECRET=                # GitLab webhook token (X-Gitlab-Token header)
GITLAB_PROJECT_IDS=                   # Comma-separated numeric project IDs for webhook auto-registration (optional)
DEVTRACK_WEBHOOK_PUBLIC_URL=          # Public URL of this server (e.g. <https://myserver.com>) — used for webhook auto-registration
WEBHOOK_NOTIFY_OS=true
WEBHOOK_NOTIFY_TERMINAL=true
SHUTDOWN_GRACE_PERIOD_SECONDS=0.5    # Seconds to wait before sending SIGTERM on /trigger/shutdown

## PROJECT SYNC (periodic sync of project data from external platforms)

### Project Synchronization

PROJECT_SYNC_ENABLED=false
PROJECT_SYNC_INTERVAL_SECS=300

## TICKET ALERTER (polls GitHub for events relevant to you)

### Alert Configuration

ALERT_ENABLED=true
ALERT_POLL_INTERVAL_SECS=300
ALERT_GITHUB_ENABLED=true
ALERT_AZURE_ENABLED=true
ALERT_NOTIFY_ASSIGNED=true
ALERT_NOTIFY_COMMENTS=true
ALERT_NOTIFY_STATUS_CHANGES=true
ALERT_NOTIFY_REVIEW_REQUESTED=true
ALERT_JIRA_ENABLED=true

Optional: set your Azure DevOps display name or email to filter out your own comments

AZURE_EMAIL=you@yourorg.com

## AI PROJECT PLANNING (/newproject Telegram command)

### Project Planning Configuration

Enable the /newproject AI project planning feature

NEWPROJECT_ENABLED=true

Base URL for the spec review web form (where the webhook server runs)

PMs receive a link to this URL to review/edit/approve the generated spec

Set to your public or local webhook server URL

SPEC_REVIEW_BASE_URL=http://localhost:8089

## VACATION MODE (devtrack vacation on/off/status + Telegram /vacation + Slack /devtrack vacation)

### Vacation Mode Settings

Minimum LLM confidence (0-1) to auto-submit a work update while on vacation

VACATION_CONFIDENCE_THRESHOLD=0.7

Set to false to log auto-generated updates without posting to PM

VACATION_AUTO_SUBMIT=true

## WORK SESSION TRACKING (devtrack work start/stop/report + Telegram /workstart)

### Work Session Configuration

Auto-generate and email the EOD report at this hour (24h, 0 = disabled)

EOD_REPORT_HOUR=18

Default recipient for auto EOD reports (optional; override per-command with --email)

EOD_REPORT_EMAIL=you@org.com

Auto-stop any active session after N minutes of no new commits (0 = disabled)

WORK_SESSION_AUTO_STOP_MINUTES=0

## ADMIN CONSOLE (CS-3 — devtrack admin-start)

### Admin Console Configuration

Port for the Admin Console web UI (separate from webhook server port 8089)

ADMIN_PORT=8090
ADMIN_HOST=0.0.0.0

Admin credentials — required for devtrack admin-start

ADMIN_PASSWORD may be a bcrypt hash ($2b$...) or plain text (local dev only)

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

JWT signing secret — auto-generated (ephemeral) if not set; set for persistent sessions

ADMIN_SECRET_KEY=

Embed admin console directly on the main webhook server (single-process mode).
When true, admin routes are mounted at /admin on the webhook server (port 8089).
When false (default), admin runs as a separate process on ADMIN_PORT.

ADMIN_EMBED=false

Session lifetime in hours (default: 8)

ADMIN_SESSION_HOURS=8

# Scrypt password-hashing parameters (used when hashing/verifying admin passwords).
# n: CPU/memory cost factor — must be a power of 2 (e.g. 16384, 32768).
# r: block size. p: parallelisation factor. dklen: derived key length in bytes.
SCRYPT_N=16384
SCRYPT_R=8
SCRYPT_P=1
SCRYPT_DKLEN=32

# Admin dashboard HTMX auto-refresh intervals
STATS_REFRESH_INTERVAL_SECONDS=30    # How often the trigger stats panel auto-refreshes (seconds)
PROCESS_REFRESH_INTERVAL_SECONDS=15  # How often the process table auto-refreshes (seconds)
AUDIT_LOG_LIMIT=200                  # Maximum audit log entries returned by the admin UI
LICENSE_CONTACT_EMAIL=license@devtrack.dev  # Support email shown on the license page

# ── Telemetry ─────────────────────────────────────────────────────────────────
# Anonymous install/active ping endpoint. Set to empty string to disable pings
# without running `devtrack telemetry off`. Default: https://ping.devtrack.dev
# DEVTRACK_PING_URL=https://ping.devtrack.dev

# ── DevTrack cloud / API ──────────────────────────────────────────────────────
# Cloud API URL (empty for self-hosted / local-only use)
DEVTRACK_API_URL=
# Auto-accept terms of service on first install (CI/headless deployments)
DEVTRACK_AUTO_ACCEPT_TERMS=false

# ── Azure AD (for spec emailer and work-tracker EOD email via MS Graph) ───────
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# ── GitHub extras ─────────────────────────────────────────────────────────────
# Sync window: 0 = full resync, N = last N hours only
GITHUB_SYNC_WINDOW_HOURS=0
# Optional path for GitHub branch-analysis log output (default: Data/logs/)
GITHUB_LOG_PATH=

# ── Commit enhancement ────────────────────────────────────────────────────────
# Set to true to enable AI commit message enhancement via devtrack git commit
COMMIT_ENHANCE_MODE=false
