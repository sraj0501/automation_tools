# DevTrack .env_sample — copy to .env and fill in your values

# All variables are required unless marked optional

# =============================================================================

# PATHS

# =============================================================================

# Absolute path to the automation_tools repo root (required)

PROJECT_ROOT=/path/to/automation_tools
DEVTRACK_HOME=${PROJECT_ROOT}/devtrack-bin
DEVTRACK_WORKSPACE=${PROJECT_ROOT}

DATA_DIR=${PROJECT_ROOT}/Data
DATABASE_DIR=${DATA_DIR}/db
LOG_DIR=${DATA_DIR}/logs
PID_DIR=${DATA_DIR}/pids
CONFIG_DIR_PATH=${DATA_DIR}/configs
LEARNING_DIR_PATH=${DATA_DIR}/learning

# =============================================================================

# DAEMON / CLI INTERNALS

# =============================================================================

IPC_HOST=127.0.0.1
IPC_PORT=35893
IPC_CONNECT_TIMEOUT_SECS=5
PYTHON_BRIDGE_SCRIPT=python_bridge.py
CLI_BINARY_NAME=devtrack
CONFIG_FILE_NAME=config.yaml
DATABASE_FILE_NAME=devtrack.db
PID_FILE_NAME=daemon.pid
LOG_FILE_NAME=daemon.log
LEARNING_DIR_NAME=learning
CONFIG_DIR_NAME=.devtrack
CLI_APP_NAME=DevTrack
CLI_DAEMON_NAME=devtrack

# Set to true to commit without pushing (useful when post-commit hooks do the push)

DEVTRACK_COMMIT_ONLY=false

# =============================================================================

# LLM PROVIDERS

# =============================================================================

# Primary LLM provider for devtrack (commit messages, reports, descriptions)

# Values: ollama | openai | groq | anthropic | lmstudio

LLM_PROVIDER=ollama

# --- Ollama (local, free) ---

OLLAMA_HOST=<http://localhost:11434>
OLLAMA_MODEL=llama3.2

# --- LM Studio (local, OpenAI-compatible) ---

LMSTUDIO_HOST=<http://localhost:1234/v1>

# --- OpenAI (optional — used as primary or fallback when OPENAI_API_KEY is set) ---

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (optional — used as primary or fallback when ANTHROPIC_API_KEY is set) ---

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Groq (optional — used as primary or fallback when GROQ_API_KEY is set) ---

GROQ_API_KEY=
GROQ_HOST=<https://api.groq.com/openai/v1>
GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================

# GIT-SAGE (devtrack sage)

# =============================================================================

# Provider for git-sage specifically. Defaults to LLM_PROVIDER if not set

# Values: ollama | openai | groq | anthropic | lmstudio

GIT_SAGE_PROVIDER=ollama
GIT_SAGE_DEFAULT_MODEL=llama3.2

# GIT_SAGE_BASE_URL=          # optional: override base URL for git-sage provider

# GIT_SAGE_API_KEY=           # optional: override API key for git-sage provider

# =============================================================================

# LLM GENERATION PARAMETERS

# =============================================================================

# Temperature: 0.0 = deterministic, 1.0 = creative

# Max tokens: output length limit

COMMIT_LLM_TEMPERATURE=0.1
COMMIT_LLM_MAX_TOKENS=1000

REPORT_LLM_TEMPERATURE=0.3
REPORT_LLM_MAX_TOKENS=600

PERSONALIZATION_LLM_TEMPERATURE=0.7
PERSONALIZATION_LLM_MAX_TOKENS=300

DESCRIPTION_LLM_TEMPERATURE=0.3
DESCRIPTION_LLM_MAX_TOKENS=300

# =============================================================================

# TIMEOUTS AND DELAYS (required — no defaults)

# =============================================================================

HTTP_TIMEOUT_SHORT=10
HTTP_TIMEOUT=30
HTTP_TIMEOUT_LONG=60
IPC_RETRY_DELAY_MS=2000
LLM_REQUEST_TIMEOUT_SECS=120
PROMPT_TIMEOUT_SIMPLE_SECS=30
PROMPT_TIMEOUT_WORK_SECS=60
PROMPT_TIMEOUT_TASK_SECS=120
SENTIMENT_ANALYSIS_WINDOW_MINUTES=120

# =============================================================================

# APP SETTINGS

# =============================================================================

PROMPT_INTERVAL=30
WORK_HOURS_ONLY=true
WORK_START_HOUR=9
WORK_END_HOUR=18
TIMEZONE=UTC
LOG_LEVEL=info
AUTO_SYNC=true
OUTPUT_TYPE=both
DAILY_REPORT_TIME=18:00
WEEKLY_REPORT_DAY=Friday
SEND_ON_TRIGGER=false
SEND_DAILY_SUMMARY=true

# =============================================================================

# INTEGRATIONS

# =============================================================================

# --- Azure DevOps ---

AZURE_DEVOPS_PAT=your_azure_devops_pat_here
AZURE_ORGANIZATION=your_azure_org
AZURE_PROJECT=your_azure_project
AZURE_API_KEY=your_azure_devops_api_key_here
AZURE_API_VERSION=7.1
AZURE_EXCEL_FILE=${PROJECT_ROOT}/backend/data/tasks.xlsx
AZURE_EXCEL_SHEET=my_tasks
AZURE_PARENT_WORK_ITEM_ID=
AZURE_DEFAULT_ASSIGNEE=
AZURE_STARTING_WORK_ITEM_ID=0
EMAIL=<your_email@example.com>

# --- GitHub ---

GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=

# --- GitLab ---

GITLAB_URL=https://gitlab.com
GITLAB_PAT=your_gitlab_personal_access_token
GITLAB_PROJECT_ID=                      # numeric project ID (required for create/milestones)
GITLAB_SYNC_ENABLED=false
GITLAB_SYNC_WINDOW_HOURS=0              # 0=full, N=last N hours
GITLAB_POLL_ENABLED=false
GITLAB_POLL_INTERVAL_MINS=5

# --- PM Agent ---

PM_AGENT_MAX_ITEMS_PER_LEVEL=10
PM_AGENT_DEFAULT_PLATFORM=azure

# --- Jira ---

JIRA_API_TOKEN=your_jira_api_token_here
JIRA_URL=<https://yourorg.atlassian.net>
JIRA_EMAIL=<your_email@example.com>
JIRA_PROJECT_KEY=PROJ

# --- Email / Microsoft Teams ---

EMAIL_TO_ADDRESSES=<dev@example.com>
EMAIL_CC_ADDRESSES=<manager@example.com>
EMAIL_MANAGER=<manager@example.com>
EMAIL_SUBJECT="DevTrack Daily Report"
TEAMS_CHANNEL_ID=your_teams_channel_id
TEAMS_CHANNEL_NAME="DevTrack Updates"
TEAMS_CHAT_ID=your_teams_chat_id
TEAMS_CHAT_TYPE=channel
TEAMS_WEBHOOK_URL=<https://outlook.office.com/webhook/your-webhook-url>
TEAMS_MENTION_USER=false

# Teams sentiment analysis — target sender name for responsiveness tracking

SENTIMENT_TARGET_SENDER=

# =============================================================================

# SEMANTIC MODEL

# =============================================================================

SEMANTIC_MODEL_NAME=all-MiniLM-L6-v2

# =============================================================================

# LEARNING (personalization)

# =============================================================================

LEARNING_PYTHON_PATH=python3
LEARNING_SCRIPT_PATH=${PROJECT_ROOT}/backend/learning_integration.py
LEARNING_DAILY_SCRIPT_PATH=${PROJECT_ROOT}/backend/run_daily_learning.py
LEARNING_DEFAULT_DAYS=30

# Automatic daily cron collection

LEARNING_CRON_ENABLED=false
LEARNING_CRON_SCHEDULE="0 20 ** *"
LEARNING_HISTORY_DAYS=30

# RAG personalization (vector-store few-shot examples, powered by ChromaDB + Ollama)

# Requires: nomic-embed-text pulled in Ollama (`ollama pull nomic-embed-text`)

PERSONALIZATION_RAG_ENABLED=true
PERSONALIZATION_EMBED_MODEL=nomic-embed-text
PERSONALIZATION_RAG_K=3

# Optional: override ChromaDB persistence directory (default: DATA_DIR/learning/chroma)

# PERSONALIZATION_CHROMA_DIR=${DATA_DIR}/learning/chroma

# =============================================================================

# INFRASTRUCTURE (docker-compose)

# =============================================================================

# --- MongoDB (leave MONGODB_URI empty to use file-based storage instead) ---

MONGO_USER=devtrack
MONGO_PASSWORD=devtrack
MONGO_PORT=27017
MONGODB_DB_NAME=devtrack
MONGODB_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@localhost:${MONGO_PORT}/${MONGODB_DB_NAME}?authSource=admin

# --- Redis ---

REDIS_PASSWORD=devtrack
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:${REDIS_PORT}/0

# --- PostgreSQL ---

POSTGRES_USER=devtrack
POSTGRES_PASSWORD=devtrack
POSTGRES_DB=devtrack
POSTGRES_PORT=5432
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# =============================================================================

# OFFLINE RESILIENCE (store-and-forward, health monitoring, deferred commits)

# =============================================================================

HEALTH_CHECK_INTERVAL_SECS=30
HEALTH_AUTO_RESTART_PYTHON=true
HEALTH_AUTO_RESTART_WEBHOOK=true
HEALTH_MAX_RESTARTS_PER_HOUR=3
QUEUE_DRAIN_INTERVAL_SECS=10
QUEUE_MAX_RETRIES=10
QUEUE_RETENTION_DAYS=7
DEFERRED_COMMIT_EXPIRY_HOURS=72

# =============================================================================

# TELEGRAM BOT (remote control via Telegram)

# =============================================================================

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_NOTIFY_COMMITS=false
TELEGRAM_NOTIFY_TRIGGERS=true
TELEGRAM_NOTIFY_HEALTH=true
HEALTH_AUTO_RESTART_TELEGRAM=true

# =============================================================================

# BUILD METADATA

# =============================================================================

DEVTRACK_VERSION=0.1.0-alpha
DEVTRACK_BUILD_DATE=2026-03-02

# =============================================================================

# AZURE DEVOPS SYNC (bidirectional sync with Azure DevOps work items)

# =============================================================================

AZURE_SYNC_ENABLED=false
AZURE_SYNC_AUTO_COMMENT=true
AZURE_SYNC_AUTO_TRANSITION=false
AZURE_SYNC_CREATE_ON_NO_MATCH=false
AZURE_SYNC_MATCH_THRESHOLD=0.7
# Sync window for devtrack azure-sync: 0 = full resync, N = last N hours only
AZURE_SYNC_WINDOW_HOURS=0
# Assignment poller: notify Telegram when a new work item is assigned to you
AZURE_POLL_ENABLED=false
AZURE_POLL_INTERVAL_MINS=5

# =============================================================================

# WEBHOOK SERVER (receives events from Azure DevOps, GitHub, Jira)

# =============================================================================

WEBHOOK_ENABLED=false
WEBHOOK_PORT=8089
WEBHOOK_HOST=0.0.0.0
WEBHOOK_AZURE_USERNAME=devtrack
WEBHOOK_AZURE_PASSWORD=
WEBHOOK_GITHUB_SECRET=
WEBHOOK_NOTIFY_OS=true
WEBHOOK_NOTIFY_TERMINAL=true

# =============================================================================

# PROJECT SYNC (periodic sync of project data from external platforms)

# =============================================================================

PROJECT_SYNC_ENABLED=false
PROJECT_SYNC_INTERVAL_SECS=300
