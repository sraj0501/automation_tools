# DevTrack Configuration
# Copy this file to .env and adjust paths as needed
# ALL VALUES ARE REQUIRED - DevTrack will fail startup if any are missing
# Use absolute paths (e.g., /home/user/projects or C:\\Users\\user\\projects)

# Project root directory (where Python bridge script is located)
# Local: /home/user/Documents/GitHub/automation_tools
# Docker: /app
PROJECT_ROOT=/home/user/Documents/GitHub/automation_tools

# DevTrack home directory (config, logs, database)
DEVTRACK_HOME=/home/user/.devtrack

# IPC server configuration
IPC_HOST=127.0.0.1
IPC_PORT=35893

# File names (customize if needed)
PYTHON_BRIDGE_SCRIPT=python_bridge.py
CLI_BINARY_NAME=devtrack-cli
CONFIG_FILE_NAME=config.yaml
DATABASE_FILE_NAME=devtrack.db
PID_FILE_NAME=daemon.pid
LOG_FILE_NAME=daemon.log

# Directory names (customize if needed)
LEARNING_DIR_NAME=learning
CONFIG_DIR_NAME=.devtrack

# CLI identifiers
CLI_APP_NAME=DevTrack
CLI_DAEMON_NAME=devtrack

# Workspace directory
DEVTRACK_WORKSPACE=/home/user/Documents/GitHub

# Ollama endpoint
OLLAMA_HOST=http://host.docker.internal:11434
