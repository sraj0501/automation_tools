# Copy this file to .env and adjust paths as needed.
# Use absolute paths on Windows (e.g., C:\\Users\\you\\Projects\\automation_tools)
# or POSIX paths on macOS/Linux (e.g., /Users/you/Projects/automation_tools).
DEVTRACK_WORKSPACE=.

# Point to the host's Ollama endpoint (host.docker.internal works on macOS/Linux/Windows).
# Change to http://127.0.0.1:11434 if host.docker.internal is unavailable on your distro.
OLLAMA_HOST=http://host.docker.internal:11434
